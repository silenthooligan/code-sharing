# Copy this to secrets.yaml in each device directory (or symlink), then fill in.
# secrets.yaml is gitignored by default so your credentials don't end up on GitHub.

# WiFi the dongle should join (typically your IoT VLAN).
wifi_ssid: "your-iot-ssid"
wifi_password: "your-iot-passphrase"

# ESPHome native API encryption key. Generate one with:
#   openssl rand -base64 32
api_encryption_key: "REPLACE_ME_BASE64_32_BYTES"

# OTA password for over-the-air firmware updates after first flash.
# Generate one with:
#   openssl rand -hex 16
ota_password: "REPLACE_ME_HEX_32_CHARS"
